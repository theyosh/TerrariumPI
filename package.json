{
  "name": "svelte-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "MIX_ENV=prod NODE_ENV=prod NODE_OPTIONS=--max-old-space-size=1536 cross-env-file -p ./.env.prod.json npx rollup -c",
    "build:dev": "cross-env-file -p ./.env.dev.json npx rollup -c",
    "dev": "cross-env-file -p ./.env.dev.json npx rollup -c -w",
    "start": "npx serve -n -l 5000 public",
    "format": "prettier --write ./docs ./gui *.md"
  },
